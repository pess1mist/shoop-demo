# 环境变量配置示例
# 复制此文件为 .env 并修改为实际配置

# 数据库配置
DB_URL=jdbc:mysql://localhost:3306/shuju?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_password_here

# JWT 配置（至少 32 位随机字符串）
JWT_SECRET=replace_with_a_secure_random_secret_at_least_32_chars
JWT_EXPIRATION=86400000

# CORS 配置（仅开发）
CORS_ALLOWED_ORIGIN=http://localhost:5173

# 服务器端口（可选）
SERVER_PORT=8080
